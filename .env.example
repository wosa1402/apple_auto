# Flask secret key (auto-generated if not set)
# SECRET_KEY=your-secret-key

# Admin login password
ADMIN_PASSWORD=admin

# SQLite database path
DATABASE_PATH=data/appleid.db

# WebDriver: "local" for local Chrome, or remote URL like "http://host:4444"
WEBDRIVER_URL=local

# Run Chrome headless
HEADLESS=true

# Language: zh_cn, en_us, vi_vn
LANG=zh_cn

# Data directory for DB, logs, error screenshots
DATA_DIR=data

# Log level
LOG_LEVEL=INFO

# Web server
HOST=0.0.0.0
PORT=5000
